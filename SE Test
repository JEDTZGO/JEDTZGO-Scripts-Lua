local Players = game:GetService("Players")
local WorkspaceService = game:GetService("Workspace")

local LocalPlayer = Players.LocalPlayer
local mouse = LocalPlayer:GetMouse()
local CurrentCamera = WorkspaceService.CurrentCamera

local ScriptSettings = {
    Aimbot = {
        Enabled = true,
        TargetHitbox = "root",
        FieldOfView = 150,
        SmoothingAmount = 5
    },
    Visuals = {
        DrawFOV = true,
        FOVColor = Color3.fromRGB(255, 255, 255),
        EnemyBoxColor = Color3.fromRGB(255, 0, 0)
    }
}

-- ── MATCHA UI ────────────────────────────────────────────────────────────────
UI.AddTab("Script", function(tab)

    local aim = tab:Section("Aimbot", "Left")
    aim:Toggle("aim_on", "Enabled", ScriptSettings.Aimbot.Enabled, function(v)
        ScriptSettings.Aimbot.Enabled = v
        FieldOfViewRing.Visible = v and ScriptSettings.Visuals.DrawFOV
    end)
    aim:Combo("aim_hitbox", "Hitbox", {"root", "head", "torso"}, 0, function(_, text)
        ScriptSettings.Aimbot.TargetHitbox = text
    end)
    aim:SliderFloat("aim_smooth", "Smoothing", 0.1, 20.0, ScriptSettings.Aimbot.SmoothingAmount, "%.1f", function(v)
        ScriptSettings.Aimbot.SmoothingAmount = v
    end)

    local vis = tab:Section("Visuals", "Right")
    vis:Toggle("fov_draw", "Draw FOV", ScriptSettings.Visuals.DrawFOV, function(v)
        ScriptSettings.Visuals.DrawFOV = v
        FieldOfViewRing.Visible = v and ScriptSettings.Aimbot.Enabled
    end)
    vis:ColorPicker("fov_col", 1, 1, 1, 1, function(col)
        ScriptSettings.Visuals.FOVColor = col
        FieldOfViewRing.Color = col
    end)
    vis:Toggle("box_on", "Enemy Box", true)
    vis:ColorPicker("box_col", 1, 0, 0, 1, function(col)
        ScriptSettings.Visuals.EnemyBoxColor = col
    end)

    local misc = tab:Section("Misc", "Right")
    misc:Button("Reset", function()
        UI.SetValue("aim_on", true)
        UI.SetValue("aim_smooth", 5.0)
        UI.SetValue("fov_draw", true)
        UI.SetValue("box_on", true)
        ScriptSettings.Aimbot.Enabled = true
        ScriptSettings.Aimbot.SmoothingAmount = 5
        ScriptSettings.Visuals.DrawFOV = true
        FieldOfViewRing.Visible = true
    end)
end)

-- ── LOGICA PRINCIPAL (sin cambios) ───────────────────────────────────────────
local function IsTeammateFromHitbox(hitbox)
    if not hitbox or not hitbox.Parent then return false end
    local model = hitbox.Parent
    local torso = model:FindFirstChild("torso")
    if not torso then return false end
    return torso:FindFirstChild("tag") ~= nil
end

local FieldOfViewRing = Drawing.new("Circle")
FieldOfViewRing.Radius = ScriptSettings.Aimbot.FieldOfView
FieldOfViewRing.Color = ScriptSettings.Visuals.FOVColor
FieldOfViewRing.Thickness = 1
FieldOfViewRing.NumSides = 64
FieldOfViewRing.Filled = false
FieldOfViewRing.Visible = ScriptSettings.Aimbot.Enabled and ScriptSettings.Visuals.DrawFOV

local function PerformMouseMovement(targetScreenPosition, smoothingValue)
    local differenceX = (targetScreenPosition.X - mouse.X) / smoothingValue
    local differenceY = (targetScreenPosition.Y - mouse.Y) / smoothingValue
    mousemoverel(differenceX, differenceY)
end

local drawingObjectPool = {}
local cachedEnemyParts = {}

local function getPoolBox(index)
    if not drawingObjectPool[index] then
        local b = Drawing.new("Square")
        b.Filled = false
        b.Thickness = 1
        b.Visible = false
        drawingObjectPool[index] = b
    end
    return drawingObjectPool[index]
end

spawn(function()
    while true do
        task.wait(1)
        local newParts = {}
        for _, folderContainer in pairs(WorkspaceService:GetChildren()) do
            if folderContainer.Name == "Folder" then
                for _, entityModel in pairs(folderContainer:GetChildren()) do
                    if entityModel.Name == "Model" and entityModel.ClassName == "Model" then
                        local hitboxPart = entityModel:FindFirstChild(ScriptSettings.Aimbot.TargetHitbox)
                        if hitboxPart then
                            table.insert(newParts, hitboxPart)
                        end
                    end
                end
            end
        end
        cachedEnemyParts = newParts
    end
end)

while true do
    task.wait(0.016)

    if FieldOfViewRing.Visible then
        FieldOfViewRing.Position = Vector2.new(mouse.X, mouse.Y)
    end

    local enemiesOnScreen = {}
    local activeDrawingCount = 1
    local showBoxes = UI.GetValue("box_on")

    for index = #cachedEnemyParts, 1, -1 do
        local enemyHitbox = cachedEnemyParts[index]

        if enemyHitbox and enemyHitbox.Parent and enemyHitbox:IsDescendantOf(WorkspaceService) then
            if IsTeammateFromHitbox(enemyHitbox) then
                continue
            end

            local hitboxWorldPosition = enemyHitbox.Position
            local headScreenPos, headIsVisible = WorldToScreen(
                Vector3.new(hitboxWorldPosition.X, hitboxWorldPosition.Y + 2.5, hitboxWorldPosition.Z)
            )
            local feetScreenPos, _ = WorldToScreen(
                Vector3.new(hitboxWorldPosition.X, hitboxWorldPosition.Y - 2.5, hitboxWorldPosition.Z)
            )

            if headScreenPos and feetScreenPos and headIsVisible then
                local calculatedBoxHeight = feetScreenPos.Y - headScreenPos.Y
                if calculatedBoxHeight > 2 then
                    local rootScreenPos, rootIsVisible = WorldToScreen(hitboxWorldPosition)
                    if rootScreenPos and rootIsVisible then
                        table.insert(enemiesOnScreen, { ScreenPosition = rootScreenPos })

                        if showBoxes then
                            local espBox = getPoolBox(activeDrawingCount)
                            espBox.Color = ScriptSettings.Visuals.EnemyBoxColor
                            local calculatedBoxWidth = calculatedBoxHeight / 1.5
                            espBox.Position = Vector2.new(
                                headScreenPos.X - (calculatedBoxWidth / 2),
                                headScreenPos.Y
                            )
                            espBox.Size = Vector2.new(calculatedBoxWidth, calculatedBoxHeight)
                            espBox.Visible = true
                            activeDrawingCount = activeDrawingCount + 1
                        end
                    end
                end
            end
        else
            table.remove(cachedEnemyParts, index)
        end
    end

    for poolIndex = activeDrawingCount, #drawingObjectPool do
        drawingObjectPool[poolIndex].Visible = false
    end
    local maxNeeded = activeDrawingCount + 5
    for poolIndex = maxNeeded, #drawingObjectPool do
        drawingObjectPool[poolIndex]:Remove()
        drawingObjectPool[poolIndex] = nil
    end

    if ScriptSettings.Aimbot.Enabled and ismouse2pressed() and #enemiesOnScreen > 0 then
        local bestTarget = nil
        local minimumDistance = ScriptSettings.Aimbot.FieldOfView
        local mX = mouse.X
        local mY = mouse.Y
        for _, targetData in pairs(enemiesOnScreen) do
            local dx = targetData.ScreenPosition.X - mX
            local dy = targetData.ScreenPosition.Y - mY
            local distance = math.sqrt(dx * dx + dy * dy)
            if distance < minimumDistance then
                minimumDistance = distance
                bestTarget = targetData
            end
        end
        if bestTarget then
            PerformMouseMovement(bestTarget.ScreenPosition, ScriptSettings.Aimbot.SmoothingAmount)
        end
    end
end
